<body>
  <%- include('partials/header', { headerClass: 'header-china', pageTitle: 'Chinese Art' }) %>
  <main class="main">
    <h2 class="gallery-title" style="text-align: center;">Travelers Among Mountains and Streams</h2>
    <div class="artwork-detail-image-wrap">
      <img src="/images/travelers-mountains-streams.jpg" alt="Travelers Among Mountains and Streams by Fan Kuan, Northern Song dynasty landscape" />
