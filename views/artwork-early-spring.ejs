  <%- include('partials/header', { headerClass: 'header-china', pageTitle: 'Chinese Art' }) %>
  <main class="main">
    <h2 class="gallery-title" style="text-align: center;">Early Spring</h2>
    <div class="artwork-detail-image-wrap">
      <img src="/images/early-spring.png" alt="Early Spring by Guo Xi, Northern Song dynasty landscape painting" />
