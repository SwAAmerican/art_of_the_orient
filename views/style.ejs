<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %> – Art of the Orient</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header', { headerClass, pageTitle }) %>
  <main class="main">
    <h2 class="gallery-title"><%= pageTitle %></h2>
    <% if (typeof region !== 'undefined' && region === 'china') { %>
    <h3 class="gallery-subtitle">Chinese Styles</h3>
    <section class="production-techniques">
      <a href="/style/china/gongbi" class="production-technique-card">
        <figure class="production-technique-figure">
          <img src="/images/silk-sizing.png" alt="Gongbi: meticulous Chinese fine-line brushwork" />
        </figure>
        <p class="production-technique-subtitle">Gongbi</p>
      </a>
      <a href="/style/china/xieyi" class="production-technique-card">
        <figure class="production-technique-figure">
          <img src="/images/silk-sizing.png" alt="Xieyi: freehand expressive ink painting" />
        </figure>
        <p class="production-technique-subtitle">Xieyi</p>
      </a>
      <a href="/style/china/shanshui" class="production-technique-card">
        <figure class="production-technique-figure">
          <img src="/images/silk-sizing.png" alt="Shanshui: mountain and water landscape" />
        </figure>
        <p class="production-technique-subtitle">Shanshui</p>
      </a>
      <a href="/style/china/huaniao" class="production-technique-card">
        <figure class="production-technique-figure">
          <img src="/images/silk-sizing.png" alt="Huaniao: bird-and-flower painting" />
        </figure>
        <p class="production-technique-subtitle">Huaniao</p>
      </a>
      <a href="/style/china/literati" class="production-technique-card">
        <figure class="production-technique-figure">
          <img src="/images/silk-sizing.png" alt="Literati: scholar-amateur painting" />
        </figure>
        <p class="production-technique-subtitle">Literati</p>
      </a>
    </section>
    <% } %>
  </main>
  <script src="/js/nav.js"></script>
</body>
</html>
