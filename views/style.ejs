<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %> – Art of the Orient</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header', { headerClass, pageTitle }) %>
  <main class="main">
    <h2 class="gallery-title"><%= pageTitle %></h2>
    <% const showChineseStyles = (typeof region !== 'undefined' && region === 'china') || pageTitle === 'Chinese Style'; %>
    <% if (showChineseStyles) { %>
    <section class="production-techniques">
      <a href="/style/china/gongbi" class="production-technique-card">
        <figure class="production-technique-figure">
          <img src="/images/silk-sizing.png" alt="Gongbi: meticulous Chinese fine-line brushwork" />
        </figure>
        <p class="production-technique-subtitle">Gongbi</p>
      </a>
      <a href="/style/china/xieyi" class="production-technique-card">
        <figure class="production-technique-figure">
          <img src="/images/silk-sizing.png" alt="Xieyi: freehand expressive ink painting" />
        </figure>
        <p class="production-technique-subtitle">Xieyi</p>
      </a>
      <a href="/style/china/shanshui" class="production-technique-card">
        <figure class="production-technique-figure">
          <img src="/images/silk-sizing.png" alt="Shanshui: mountain and water landscape" />
        </figure>
        <p class="production-technique-subtitle">Shanshui</p>
      </a>
      <a href="/style/china/huaniao" class="production-technique-card">
        <figure class="production-technique-figure">
          <img src="/images/silk-sizing.png" alt="Huaniao: bird-and-flower painting" />
        </figure>
        <p class="production-technique-subtitle">Huaniao</p>
      </a>
      <a href="/style/china/literati" class="production-technique-card">
        <figure class="production-technique-figure">
          <img src="/images/silk-sizing.png" alt="Literati: scholar-amateur painting" />
        </figure>
        <p class="production-technique-subtitle">Literati</p>
      </a>
    </section>
    <% } %>
    <% const showKoreanStyles = (typeof region !== 'undefined' && region === 'korea') || pageTitle === 'Korean Style'; %>
    <% if (showKoreanStyles) { %>
    <section class="production-techniques">
      <a href="/style/korea/minhwa" class="production-technique-card">
        <figure class="production-technique-figure">
          <img src="/images/symbolism-tiger-magpie.png" alt="Minhwa: Korean folk painting" />
        </figure>
        <p class="production-technique-subtitle">Minhwa</p>
      </a>
      <a href="/style/korea/jingyeong-sansuhwa" class="production-technique-card">
        <figure class="production-technique-figure">
          <img src="/images/symbolism-tiger-magpie.png" alt="Jingyeong Sansuhwa: true-view landscape" />
        </figure>
        <p class="production-technique-subtitle">Jingyeong Sansuhwa</p>
      </a>
      <a href="/style/korea/pungsokdo" class="production-technique-card">
        <figure class="production-technique-figure">
          <img src="/images/symbolism-tiger-magpie.png" alt="Pungsokdo: genre painting of customs" />
        </figure>
        <p class="production-technique-subtitle">Pungsokdo</p>
      </a>
      <a href="/style/korea/bulhwa" class="production-technique-card">
        <figure class="production-technique-figure">
          <img src="/images/symbolism-tiger-magpie.png" alt="Bulhwa: Buddhist painting" />
        </figure>
        <p class="production-technique-subtitle">Bulhwa</p>
      </a>
    </section>
    <% } %>
  </main>
  <script src="/js/nav.js"></script>
</body>
</html>
