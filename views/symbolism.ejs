<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %> – Art of the Orient</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header', { headerClass, pageTitle }) %>
  <main class="main">
    <h2 class="gallery-title"><%= pageTitle %></h2>
    <section class="production-techniques">
      <a href="/symbolism/cherry-blossoms" class="production-technique-card">
        <figure class="production-technique-figure">
          <img src="https://upload.wikimedia.org/wikipedia/commons/0/0e/Cherry_Trees_along_Gokacho_in_New_Yoshiwara_by_Utagawa_Hiroshige_c1835.png" alt="Utagawa Hiroshige ukiyo-e of cherry trees in bloom in Edo, Japan" />
        </figure>
        <p class="production-technique-subtitle">Cherry Blossoms</p>
      </a>
      <a href="/symbolism/four-gentlemen" class="production-technique-card">
        <figure class="production-technique-figure">
          <img src="https://upload.wikimedia.org/wikipedia/commons/2/2a/Plum_blossom%2C_orchid%2C_bamboo_and_chrysanthemum_in_ink_on_paper.jpg" alt="Chinese ink painting of plum, orchid, bamboo, and chrysanthemum, the Four Gentlemen" />
        </figure>
        <p class="production-technique-subtitle">The Four Gentlemen – Plum, Orchid, Bamboo, Chrysanthemum</p>
      </a>
      <a href="/symbolism/monastery-pavilion" class="production-technique-card">
        <figure class="production-technique-figure">
          <img src="https://upload.wikimedia.org/wikipedia/commons/7/70/Guo_Xi_-_Early_Spring_%28large_version%29.jpg" alt="Chinese landscape painting with mountains and pavilions suggesting a monastery retreat" />
        </figure>
        <p class="production-technique-subtitle">Monastery – Pavillion</p>
      </a>
      <a href="/symbolism/dragon" class="production-technique-card">
        <figure class="production-technique-figure">
          <img src="https://upload.wikimedia.org/wikipedia/commons/0/0c/Nine_Dragons_Scroll.jpg" alt="Chinese scroll painting of coiling dragons among clouds and waves" />
        </figure>
        <p class="production-technique-subtitle">Dragon</p>
      </a>
      <a href="/symbolism/crane" class="production-technique-card">
        <figure class="production-technique-figure">
          <img src="https://upload.wikimedia.org/wikipedia/commons/0/0a/Kano_Tan_yu_-_Cranes.jpg" alt="East Asian painting of white cranes, symbol of longevity" />
        </figure>
        <p class="production-technique-subtitle">Crane</p>
      </a>
      <a href="/symbolism/rabbit" class="production-technique-card">
        <figure class="production-technique-figure">
          <img src="https://upload.wikimedia.org/wikipedia/commons/1/17/Moon_and_Rabbit_by_Yoshitoshi.jpg" alt="Japanese woodblock print of a rabbit with the moon" />
        </figure>
        <p class="production-technique-subtitle">Rabbit</p>
      </a>
      <a href="/symbolism/mount-fuji" class="production-technique-card">
        <figure class="production-technique-figure">
          <img src="https://upload.wikimedia.org/wikipedia/commons/0/0c/Red_Fuji_south_wind_clear_morning.jpg" alt="Hokusai Red Fuji woodblock print of Mount Fuji in clear weather" />
        </figure>
        <p class="production-technique-subtitle">Mount Fuji</p>
      </a>
      <a href="/symbolism/kitsune-fox" class="production-technique-card">
        <figure class="production-technique-figure">
          <img src="https://upload.wikimedia.org/wikipedia/commons/9/9f/Kitsune_no_yomeiri_by_Yoshitoshi.jpg" alt="Japanese ukiyo-e of a fox-spirit procession, kitsune no yomeiri" />
        </figure>
        <p class="production-technique-subtitle">Kitsune – Fox</p>
      </a>
      <a href="/symbolism/tiger-magpie" class="production-technique-card">
        <figure class="production-technique-figure">
          <img src="https://upload.wikimedia.org/wikipedia/commons/0/0f/Tiger_and_Magpie_Joseon_Korea.jpg" alt="Korean minhwa painting of a tiger and magpie" />
        </figure>
        <p class="production-technique-subtitle">Tiger and Magpie</p>
      </a>
      <a href="/symbolism/sipjangsaeng" class="production-technique-card">
        <figure class="production-technique-figure">
          <img src="https://upload.wikimedia.org/wikipedia/commons/6/6c/Ten_Symbols_of_Longevity_screen_Korea.jpg" alt="Korean screen painting of the Ten Symbols of Longevity, Sipjangsaeng" />
        </figure>
        <p class="production-technique-subtitle">Sipjangsaeng – The Ten Longevity Symbols</p>
      </a>
      <a href="/symbolism/chaekgeori" class="production-technique-card">
        <figure class="production-technique-figure">
          <img src="https://upload.wikimedia.org/wikipedia/commons/3/38/Chaekgeori_screen_painting.jpg" alt="Korean Chaekgeori screen with books and scholarly objects" />
        </figure>
        <p class="production-technique-subtitle">Chaekgeori</p>
      </a>
    </section>
  </main>
  <script src="/js/nav.js"></script>
</body>
</html>
