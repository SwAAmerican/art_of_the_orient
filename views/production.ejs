<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %> – Art of the Orient</title>
  <link rel="stylesheet" href="/css/style.css?v=2">
</head>
<body>
  <%- include('partials/header', { headerClass, pageTitle }) %>
  <%- include('partials/page-wrap-start') %>
  <main class="main">
    <h2 class="gallery-title"><%= pageTitle %></h2>
    <section class="production-techniques">
      <a href="/production/woodblock-printing" class="production-technique-card">
        <figure class="production-technique-figure">
          <img src="/images/woodblock-printing.png" alt="Artist carving a woodblock in the ukiyo-e style" />
        </figure>
        <p class="production-technique-subtitle">Woodblock Printing</p>
      </a>
      <a href="/production/four-treasures" class="production-technique-card">
        <figure class="production-technique-figure">
          <img src="/images/four-treasures.png" alt="Four Treasures of the Study: brush, ink, inkstone, and paper for calligraphy" />
        </figure>
        <p class="production-technique-subtitle">Four Treasures of the Study</p>
      </a>
      <a href="/production/silk-sizing" class="production-technique-card">
        <figure class="production-technique-figure">
          <img src="/images/silk-sizing.png" alt="Ancient ink drawing of a figure on silk, early Chinese painting" />
        </figure>
        <p class="production-technique-subtitle">Silk Sizing</p>
      </a>
    </section>
  </main>
  <%- include('partials/page-wrap-end') %>
  <script src="/js/nav.js"></script>
</body>
</html>
